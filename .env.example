# Bills Collections Portal - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ============================================================================
# Authentication (NextAuth.js + Google OAuth)
# ============================================================================
NEXTAUTH_SECRET=your-generated-secret-here
NEXTAUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================================
# Supabase (Database)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# External APIs - NetSuite
# ============================================================================
NETSUITE_API_TOKEN=your-netsuite-token
NETSUITE_ACCOUNT_ID=your-account-id

# ============================================================================
# External APIs - Linear
# ============================================================================
LINEAR_API_KEY=your-linear-api-key

# ============================================================================
# Email Configuration
# ============================================================================
# Admin email (for promise-to-pay notifications)
ADMIN_EMAIL=christine@gobolt.com
ADMIN_REPLY_EMAIL=admin@collections.gobolt.com

# Email service selection (Phase 2)
# Uncomment one:
# RESEND_API_KEY=your-resend-api-key
# SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================================================
# Cron Jobs (Scheduled Tasks)
# ============================================================================
# Required for verifying cron job requests from Vercel
# Generate a strong random string: openssl rand -base64 32
CRON_SECRET=your-super-secret-cron-key-change-this

# ============================================================================
# Application URLs
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# Environment Mode
# ============================================================================
NODE_ENV=development
# Options: development, production

# ============================================================================
# Optional: Analytics & Monitoring
# ============================================================================
# SENTRY_DSN=your-sentry-dsn
# DATADOG_API_KEY=your-datadog-key

# ============================================================================
# Notes for Development
# ============================================================================
# 1. Use 'npx auth secret' to generate NEXTAUTH_SECRET
# 2. Use 'openssl rand -base64 32' to generate CRON_SECRET
# 3. Google OAuth credentials: https://console.cloud.google.com/
# 4. Supabase credentials: https://app.supabase.com/
# 5. NetSuite API: Admin Setup → Integration → API Keys
# 6. Linear API: Settings → API Keys
# 7. Email services (Phase 2):
#    - Resend: https://resend.com/
#    - SendGrid: https://sendgrid.com/
